{
  "name": "@app/nihonname",
  "version": "1.0.5",
  "private": true,
  "license": "GPL-3.0",
  "author": {
    "name": "haotool",
    "email": "haotool.org@gmail.com",
    "url": "https://haotool.org"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite-react-ssg build --config vite.config.ts",
    "postbuild": "node scripts/postbuild-mirror-dist.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "typecheck": "tsc --noEmit",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tsparticles/confetti": "^3.9.1",
    "@tsparticles/fireworks": "^3.9.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "1.3.0",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.5.4",
    "beasties": "0.4.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-react-ssg": "^0.8.9",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1"
  }
}
