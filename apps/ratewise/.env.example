# 環境變數範例
# 複製此檔案為 .env.local 並填入實際值

# ===================
# 必要變數 (由 CI/CD 自動設定)
# ===================

# 應用版本號 (格式: v1.2.3)
VITE_APP_VERSION=v1.2.3

# 建置時間 (ISO 8601 格式)
VITE_BUILD_TIME=2025-01-01T00:00:00.000Z

# ===================
# 選用變數
# ===================

# 網站 URL (用於 SEO 和 Open Graph)
VITE_SITE_URL=https://app.haotool.org/ratewise/

# Sentry DSN (錯誤追蹤)
# 取得方式: https://sentry.io/settings/projects/[project]/keys/
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry 除錯模式
# VITE_SENTRY_DEBUG=true

# Web Vitals 端點 (效能監控)
# VITE_VITALS_ENDPOINT=https://your-analytics-endpoint.com/vitals

# ===================
# GA4 Analytics
# ===================
# 取得方式: Google Analytics > 管理 > 資料串流 > 評估 ID
# 空值 = 不啟用（dev 預設），production 填入真實 G-ID
VITE_GA_ID=

# ===================
# Rating API (Cloudflare Worker KV)
# ===================
# 星評收集 Worker 端點；prebuild 時拉取評分快照，前端提交評分使用。
# 部署 rating-api/ Worker 後填入。空值 = 不啟用（本地不顯示評分 Modal）。
VITE_RATING_API_URL=
# Node.js prebuild 腳本使用（非 Vite VITE_ 前綴）
RATING_API_URL=
