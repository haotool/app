{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "rating-api",
	"main": "src/worker.js",
	"workers_dev": true,
	"preview_urls": false,
	"compatibility_date": "2026-03-21",
	"routes": [
		{
			"pattern": "app.haotool.org/ratewise/api/ratings*",
			"zone_name": "haotool.org",
		},
	],
	"kv_namespaces": [
		{
			"binding": "RATINGS_KV",
			"id": "b00356343fcf4a3bb48d5f8f051fe457",
			"preview_id": "8666a52be28440c2bf737031248e2a83",
		},
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true,
		},
	},
}
