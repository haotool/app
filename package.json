{
  "name": "ratewise-monorepo",
  "version": "2.9.3",
  "private": true,
  "license": "GPL-3.0",
  "author": {
    "name": "haotool",
    "email": "haotool.org@gmail.com",
    "url": "https://haotool.org"
  },
  "type": "module",
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "^24.0.0",
    "pnpm": "9.10.0"
  },
  "scripts": {
    "dev": "pnpm --filter @app/ratewise dev",
    "build": "pnpm -r build",
    "build:ratewise": "pnpm --filter @app/ratewise build",
    "build:nihonname": "pnpm --filter @app/nihonname build",
    "build:haotool": "pnpm --filter @app/haotool build",
    "build:quake-school": "pnpm --filter @app/quake-school build",
    "build:park-keeper": "pnpm --filter @app/park-keeper build",
    "build:all": "pnpm build:haotool && pnpm build:ratewise && pnpm build:nihonname && pnpm build:quake-school && pnpm build:park-keeper",
    "preview": "pnpm --filter @app/ratewise preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test -- --testPathIgnorePatterns=e2e",
    "test:integration": "pnpm -r test -- --testPathPattern=integration",
    "test:e2e": "pnpm --filter @app/ratewise exec playwright test && pnpm --filter @app/nihonname exec playwright test",
    "test:coverage": "pnpm -r run test:coverage",
    "lighthouse": "lighthouse http://localhost:4174 --view",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "unlighthouse": "unlighthouse --site http://localhost:4174",
    "test:a11y": "pnpm --filter @app/ratewise exec playwright test tests/e2e/accessibility.spec.ts --project=chromium-desktop",
    "seo:test": "pnpm lighthouse && pnpm test:a11y",
    "monitor:history": "node scripts/check-history-manifest.mjs",
    "verify:history": "node scripts/verify-history-data.mjs",
    "verify:precache": "node scripts/verify-precache-assets.mjs",
    "verify:sitemap": "node scripts/verify-sitemap-ssg.mjs",
    "verify:sitemap-2025": "node scripts/verify-sitemap-2025.mjs",
    "verify:breadcrumb": "node scripts/verify-breadcrumb-schema.mjs",
    "verify:structured-data": "node scripts/verify-structured-data.mjs",
    "verify:production-seo": "node scripts/verify-production-seo.mjs",
    "verify:production-resources": "node scripts/verify-production-resources.mjs",
    "seo:health-check": "node scripts/seo-health-check.mjs",
    "seo:audit": "node scripts/seo-full-audit.mjs",
    "purge:cdn": "bash scripts/purge-cdn-cache.sh",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky || true",
    "update:release-metadata": "node scripts/update-release-metadata.js",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm run update:release-metadata",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.83.1",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-prune": "^0.10.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.53.1",
    "unlighthouse": "^0.17.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "xml2js": "^0.6.2"
  },
  "browserslist": [
    "baseline widely available"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react-helmet-async": "1.3.0",
      "qs": "^6.14.1",
      "h3": ">=1.15.5",
      "brace-expansion@<1.1.12": "1.1.12",
      "brace-expansion@>=2.0.0 <2.0.2": "2.0.2",
      "brace-expansion@>=5.0.0 <5.0.2": "5.0.2",
      "@isaacs/brace-expansion@<5.0.1": "5.0.1",
      "fast-xml-parser": "^5.3.4",
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "undici": ">=7.18.2",
      "tmp": ">=0.2.4",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "axios@>=1.0.0 <=1.13.4": ">=1.13.5",
      "fast-xml-parser@>=4.1.3 <5.3.6": ">=5.3.6",
      "fast-xml-parser@>=4.1.3 <5.3.5": ">=5.3.5",
      "ajv@>=7.0.0 <8.18.0": ">=8.18.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=7.0.0 <7.4.8": "7.4.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.4": "10.2.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "rollup@<2.80.0": "2.80.0",
      "basic-ftp@<5.2.0": ">=5.2.0",
      "fast-xml-parser@<5.3.8": ">=5.3.8",
      "serialize-javascript": ">=7.0.3",
      "underscore@<=1.13.7": ">=1.13.8"
    }
  }
}
